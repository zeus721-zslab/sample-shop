# ============================================================
# zslab shop — 환경변수 예시 (.env.example)
# 실제 운영 시 .env 로 복사 후 값을 채우세요.
# ============================================================

# ── 앱 공통 ─────────────────────────────────────────────────
SHOP_MODE=single          # single | multi
APP_ENV=production        # local | staging | production
APP_KEY=                  # php artisan key:generate 로 생성
APP_DEBUG=false
APP_URL=https://api.zslab-shop.duckdns.org

# ── 도메인 ──────────────────────────────────────────────────
FRONTEND_URL=https://zslab-shop.duckdns.org
STAGING_FRONTEND_URL=https://zslab-stg.duckdns.org
STAGING_API_URL=https://api.zslab-stg.duckdns.org

# ── MariaDB ──────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=zslab_shop
DB_USERNAME=zslab
DB_PASSWORD=change_me_db
DB_ROOT_PASSWORD=change_me_root

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis
REDIS_URL=redis://:change_me_redis@redis:6379

# ── Elasticsearch ─────────────────────────────────────────────
ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_PASSWORD=change_me_es

# ── Laravel Sanctum ──────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=zslab-shop.duckdns.org,zslab-stg.duckdns.org
SESSION_DOMAIN=.zslab-shop.duckdns.org

# ── Queue / Cache / Session ───────────────────────────────────
QUEUE_CONNECTION=redis
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
BROADCAST_DRIVER=redis

# ── Socket.io ────────────────────────────────────────────────
SOCKET_PORT=3001
CORS_ORIGIN=https://zslab-shop.duckdns.org,https://zslab-stg.duckdns.org

# ── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@zslab-shop.duckdns.org
MAIL_FROM_NAME="zslab shop"

# ── Storage ──────────────────────────────────────────────────
FILESYSTEM_DISK=local
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-northeast-2
# AWS_BUCKET=

# ── GitHub Actions Secrets (참고용) ──────────────────────────
# PROD_SSH_HOST      : 운영 서버 IP
# PROD_SSH_USER      : zslab
# PROD_SSH_KEY       : SSH private key
# STG_SSH_HOST       : 스테이징 서버 IP
# STG_SSH_USER       : zslab
# STG_SSH_KEY        : SSH private key

# ── 관리자 계정 ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@zslab.com
ADMIN_PASSWORD=your_secure_password_here
