{
    # 내부 리버스프록시 전용 — TLS 없이 HTTP 8080으로만 동작
    auto_https off
}

# ── Production (HTTP only, 포트폴리오 FrankenPHP가 TLS 처리) ─────────

:8080 {
    encode gzip

    # 채팅 서버: /chat/* → zslab-chat (WebSocket 지원)
    # ※ Nginx가 gateway_net으로 직접 프록시하므로 이 블록은 fallback용
    handle /chat/* {
        uri strip_prefix /chat
        reverse_proxy zslab-chat:3001
    }

    # API 요청: /api/* → Laravel (CORS는 Laravel HandleCors 미들웨어가 처리)
    handle /api/* {
        reverse_proxy api:8080
    }

    # 관리자 패널: /zslab-manage/* → Laravel (세션 기반 인증)
    handle /zslab-manage* {
        reverse_proxy api:8080
    }

    # 정적 파일 (storage): /storage/* → Laravel
    handle /storage/* {
        reverse_proxy api:8080
    }

    # 나머지 → Next.js
    handle {
        reverse_proxy frontend:3000
    }
}
